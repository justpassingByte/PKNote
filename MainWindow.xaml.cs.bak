using System.Windows;
using System.Windows.Input;
using System.Windows.Threading;
using RobinHUD.Models;
using RobinHUD.Services;
using RobinHUD.Views;

namespace RobinHUD;

/// <summary>
/// Main control panel: wires all services together.
/// Services: WindowService â†’ OverlayManager â†’ SeatEngine â†’ OCR â†’ ApiClient â†’ HudRenderer
/// Startup: Check API key â†’ Show Settings if needed â†’ Initialize services
/// </summary>
public partial class MainWindow : Window
{
    // â”€â”€â”€â”€ Core Services â”€â”€â”€â”€
    private readonly WindowService _windowService;
    private readonly LayoutManager _layoutManager;
    private readonly StateStore _stateStore;
    private readonly ProfileRepository _profileRepository;
    private readonly OverlayManager _overlayManager;
    private readonly ConfigController _configController;
    private readonly ICaptureService _captureService;
    private readonly IOcrService _ocrService;
    private readonly SeatEngine _seatEngine;
    private InputController _inputController;
    private readonly NoteService _noteService;
    private readonly SettingsManager _settingsManager;

    // Services that depend on ApiClient (re-created when API key changes)
    private ApiClient _apiClient;
    private ActionEngine _actionEngine;
    private HudRenderer _hudRenderer;
    private SyncService _syncService;

    private DispatcherTimer? _syncTimer;
    private DispatcherTimer? _hudRefreshTimer;
    private ConfigProfile? _activeProfile;

    public MainWindow()
    {
        InitializeComponent();

        // â”€â”€â”€â”€ Initialize settings first â”€â”€â”€â”€
        _settingsManager = new SettingsManager();

        // â”€â”€â”€â”€ Initialize all services â”€â”€â”€â”€
        _windowService = new WindowService(_settingsManager);
        _layoutManager = new LayoutManager();
        _stateStore = new StateStore();
        _profileRepository = new ProfileRepository();
        _overlayManager = new OverlayManager(_stateStore, _layoutManager, _windowService);
        _configController = new ConfigController(_layoutManager, _profileRepository);
        _captureService = new GdiCaptureService();
        _ocrService = new TesseractOcrService(); // Real Tesseract OCR for player name recognition
        _seatEngine = new SeatEngine(_captureService, _ocrService, _layoutManager, _stateStore);
        _noteService = new NoteService(_stateStore);

        // Create API-dependent services with current settings
        _apiClient = CreateApiClient();
        _syncService = new SyncService(_apiClient, _stateStore, _settingsManager, _noteService);
        _actionEngine = new ActionEngine(_stateStore, _apiClient, _syncService);
        _inputController = new InputController(_overlayManager, _actionEngine, _stateStore);
        _hudRenderer = new HudRenderer(_layoutManager, _stateStore, _inputController, _noteService);

        // â”€â”€â”€â”€ Wire events â”€â”€â”€â”€
        _seatEngine.OnSeatChanged += SeatEngine_OnSeatChanged;
        _seatEngine.OnNameExtracted += SeatEngine_OnNameExtracted;
        _seatEngine.OnOcrFailed += SeatEngine_OnOcrFailed;
        _actionEngine.OnActionApplied += ActionEngine_OnActionApplied;
        _hudRenderer.OnOcrBadgeClicked += HudRenderer_OnOcrBadgeClicked;
        _hudRenderer.OnNoteClicked += HudRenderer_OnNoteClicked;
        _configController.OnProfileSaved += ConfigController_OnProfileSaved;
        _syncService.OnSyncStatusChanged += SyncService_OnStatusChanged;

        Loaded += MainWindow_Loaded;
        Closing += MainWindow_Closing;
        KeyDown += MainWindow_KeyDown;
    }

    private ApiClient CreateApiClient()
    {
        return new ApiClient(
            _settingsManager.ServerUrl,
            string.IsNullOrEmpty(_settingsManager.ApiKey) ? null : _settingsManager.ApiKey
        );
    }

    private void MainWindow_Loaded(object sender, RoutedEventArgs e)
    {
        _overlayManager.Initialize();
        RefreshProfileList();
        RefreshActivationUI();

        // Overlay position sync timer (300ms)
        _syncTimer = new DispatcherTimer { Interval = TimeSpan.FromMilliseconds(300) };
        _syncTimer.Tick += (_, _) =>
        {
            _overlayManager.SyncAll();
            TableCountText.Text = $"BÃ n Ä‘ang theo dÃµi: {_overlayManager.ActiveOverlayCount} / {StateStore.MaxTables}";
        };
        _syncTimer.Start();

        // HUD re-render timer (500ms)
        _hudRefreshTimer = new DispatcherTimer { Interval = TimeSpan.FromMilliseconds(500) };
        _hudRefreshTimer.Tick += (_, _) => RefreshAllHuds();
        _hudRefreshTimer.Start();

        // Check activation + start sync
        if (_settingsManager.IsActivated)
        {
            StatusText.Text = "Tráº¡ng thÃ¡i: Sáºµn sÃ ng â€” Ctrl+Shift+C: Config | Ctrl+Shift+H: Toggle HUD";
            _syncService.Start();

            // Auto-load first profile and auto-scan on startup
            if (ProfileCombo.Items.Count > 0)
            {
                ProfileCombo.SelectedIndex = 0;
                var autoScanTimer = new DispatcherTimer { Interval = TimeSpan.FromMilliseconds(500) };
                autoScanTimer.Tick += (_, _) =>
                {
                    autoScanTimer.Stop();
                    Scan_Click(this, new RoutedEventArgs());
                };
                autoScanTimer.Start();
            }
        }
        else
        {
            StatusText.Text = "Tráº¡ng thÃ¡i: ChÆ°a kÃ­ch hoáº¡t â€” VÃ o Settings Ä‘á»ƒ nháº­p API Key";
            // Show settings dialog on first launch
            ShowSettingsDialog();
        }
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ Activation UI â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private void RefreshActivationUI()
    {
        if (_settingsManager.IsActivated)
        {
            ActivationBanner.Visibility = Visibility.Collapsed;
            ScanBtn.IsEnabled = true;
            ConfigBtn.IsEnabled = true;
        }
        else
        {
            ActivationBanner.Visibility = Visibility.Visible;
            ActivationText.Text = "âš  ChÆ°a kÃ­ch hoáº¡t â€” VÃ o Settings Ä‘á»ƒ nháº­p API Key";
            ScanBtn.IsEnabled = false;
            ConfigBtn.IsEnabled = false;
        }
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ Keyboard Shortcuts â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private async void MainWindow_KeyDown(object sender, KeyEventArgs e)
    {
        if (e.Key == Key.C && Keyboard.Modifiers == (ModifierKeys.Control | ModifierKeys.Shift))
        {
            if (_configController.IsConfigMode)
            {
                await _configController.ExitConfigMode();
                _overlayManager.SetAllClickThrough(true);
                StatusText.Text = "Tráº¡ng thÃ¡i: Config Ä‘Ã£ lÆ°u âœ”";
                RefreshProfileList();
            }
            else
            {
                Config_Click(sender, e);
            }
            e.Handled = true;
        }
        else if (e.Key == Key.H && Keyboard.Modifiers == (ModifierKeys.Control | ModifierKeys.Shift))
        {
            _inputController.ToggleInteractive();
            StatusText.Text = _inputController.IsInteractive
                ? "Tráº¡ng thÃ¡i: HUD tÆ°Æ¡ng tÃ¡c ON ðŸŸ¢"
                : "Tráº¡ng thÃ¡i: HUD tÆ°Æ¡ng tÃ¡c OFF ðŸ”´ (click-through)";
            e.Handled = true;
        }
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ Event Handlers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private void SeatEngine_OnSeatChanged(SeatEvent evt)
    {
        Dispatcher.InvokeAsync(() =>
        {
            string action = evt.IsJoin ? "ngá»“i vÃ o" : evt.IsLeave ? "rá»i bÃ n" : "thay Ä‘á»•i";
            System.Diagnostics.Debug.WriteLine(
                $"[Seat] Table {evt.TableHwnd:X} S{evt.SeatIndex}: {evt.PreviousStatus} â†’ {evt.NewStatus}");
        });
    }

    private void SeatEngine_OnNameExtracted(IntPtr hwnd, int seatIdx, string name)
    {
        Dispatcher.InvokeAsync(async () =>
        {
            System.Diagnostics.Debug.WriteLine($"[OCR] Table {hwnd:X} S{seatIdx}: {name}");
            StatusText.Text = $"OCR: Gháº¿ {seatIdx} â€” {name}";

            // Fetch stats from API
            var stats = await _apiClient.SearchPlayerAsync(name);
            if (stats != null)
            {
                _stateStore.UpdateSeat(hwnd, seatIdx, s => s.Stats = stats);
            }
        });
    }

    private void SeatEngine_OnOcrFailed(IntPtr hwnd, int seatIdx)
    {
        Dispatcher.InvokeAsync(() =>
        {
            StatusText.Text = $"âš  OCR tháº¥t báº¡i: Gháº¿ {seatIdx} â€” Click '?' Ä‘á»ƒ nháº­p tay";
        });
    }

    private void ActionEngine_OnActionApplied(IntPtr hwnd, int seatIdx, ActionEvent action)
    {
        Dispatcher.InvokeAsync(() =>
        {
            StatusText.Text = $"âœ” {action.Type} â†’ {action.PlayerId} (Gháº¿ {seatIdx})";
            // Force HUD re-render for this table
            if (_activeProfile != null)
            {
                var overlay = _overlayManager.GetOverlay(hwnd);
                if (overlay != null)
                    _hudRenderer.RenderTable(hwnd, overlay, _activeProfile);
            }
        });
    }

    private void HudRenderer_OnOcrBadgeClicked(IntPtr hwnd, int seatIdx)
    {
        var overlay = _overlayManager.GetOverlay(hwnd);
        if (overlay == null) return;

        _noteService.ShowManualNameInput(overlay, hwnd, seatIdx, 100, 100,
            onNameEntered: async (tableHwnd, seat, name) =>
            {
                StatusText.Text = $"âœ” TÃªn thá»§ cÃ´ng: {name} (Gháº¿ {seat})";

                var stats = await _apiClient.SearchPlayerAsync(name);
                if (stats != null)
                    _stateStore.UpdateSeat(tableHwnd, seat, s => s.Stats = stats);
            });
    }

    private void ConfigController_OnProfileSaved(ConfigProfile profile)
    {
        Dispatcher.InvokeAsync(() =>
        {
            _activeProfile = profile;
            StatusText.Text = $"âœ” Profile '{profile.ProfileName}' Ä‘Ã£ lÆ°u ({profile.Seats.Count} seats)";
            RefreshProfileList();
            
            foreach (var win in _windowService.FindPokerWindows())
            {
                _seatEngine.StopTracking(win.Hwnd);
                _seatEngine.StartTracking(win.Hwnd, profile);
            }
        });
    }

    private void HudRenderer_OnNoteClicked(IntPtr hwnd, int seatIdx)
    {
        var seat = _stateStore.GetTable(hwnd)?.Seats.GetValueOrDefault(seatIdx);
        if (seat == null || string.IsNullOrEmpty(seat.PlayerName)) return;

        var overlay = _overlayManager.GetOverlay(hwnd);
        if (overlay != null)
        {
            _noteService.ShowQuickNoteInput(overlay, seat.PlayerName, 100, 100);
        }
    }

    private void SyncService_OnStatusChanged(string status)
    {
        Dispatcher.InvokeAsync(() =>
        {
            StatusText.Text = status;
        });
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ Button Handlers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private async void Scan_Click(object sender, RoutedEventArgs e)
    {
        if (!_settingsManager.IsActivated)
        {
            MessageBox.Show("Vui lÃ²ng kÃ­ch hoáº¡t API Key trong Settings trÆ°á»›c.", "RobinHUD",
                MessageBoxButton.OK, MessageBoxImage.Warning);
            ShowSettingsDialog();
            return;
        }

        // Auto-load profile if not yet loaded
        if (_activeProfile == null)
        {
            string? profileName = ProfileCombo.SelectedItem?.ToString() ?? ProfileCombo.Text;
            ConfigProfile? profile = null;
            
            if (!string.IsNullOrEmpty(profileName))
                profile = await _profileRepository.LoadAsync(profileName);
            
            if (profile == null)
            {
                var allProfiles = _profileRepository.ListProfiles();
                if (allProfiles.Count > 0)
                    profile = await _profileRepository.LoadAsync(allProfiles[0]);
            }
            
            if (profile != null)
            {
                _activeProfile = profile;
                StatusText.Text = $"âœ” Auto-loaded profile '{profile.ProfileName}'";
            }
        }

        var windows = _windowService.FindPokerWindows();

        if (windows.Count == 0)
        {
            StatusText.Text = "Tráº¡ng thÃ¡i: KhÃ´ng tÃ¬m tháº¥y bÃ n poker nÃ o ðŸ”";
            return;
        }

        TableList.Items.Clear();

        foreach (var win in windows)
        {
            string display = $"[{win.Hwnd:X}] {win.Title} ({win.Rect.Width}x{win.Rect.Height})";
            TableList.Items.Add(display);

            if (_activeProfile != null)
            {
                if (_overlayManager.TrySpawnOverlay(win.Hwnd, win.Title, _activeProfile))
                {
                    _seatEngine.StartTracking(win.Hwnd, _activeProfile);
                }
                
                // Clear seat states and reset baselines to force a fresh OCR scan
                foreach (var seatCfg in _activeProfile.Seats)
                {
                    _seatEngine.ResetBaseline(win.Hwnd, seatCfg.Id);
                    _stateStore.UpdateSeat(win.Hwnd, seatCfg.Id, s =>
                    {
                        s.Status = Occupancy.Unknown;
                        s.PlayerName = string.Empty;
                        s.Stats = null;
                        s.OcrFailed = false;
                    });
                }
            }
        }

        StatusText.Text = $"TÃ¬m tháº¥y {windows.Count} bÃ n â€” " +
            (_activeProfile != null ? "Ä‘ang cháº¡y OCR nháº­n diá»‡n..." : "chá»n profile rá»“i scan láº¡i");
        TableCountText.Text = $"BÃ n Ä‘ang theo dÃµi: {_overlayManager.ActiveOverlayCount} / {StateStore.MaxTables}";
        
        RefreshAllHuds();
    }

