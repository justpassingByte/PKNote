    private async void Config_Click(object sender, RoutedEventArgs e)
    {
        var windows = _windowService.FindPokerWindows();
        if (windows.Count == 0)
        {
            MessageBox.Show("Má»Ÿ poker client trÆ°á»›c khi config.", "RobinHUD",
                MessageBoxButton.OK, MessageBoxImage.Information);
            return;
        }

        var target = windows[0];
        string typedName = ProfileCombo.Text ?? "default";
        
        ConfigProfile profile;
        if (_activeProfile != null && !string.Equals(_activeProfile.ProfileName, typedName, StringComparison.OrdinalIgnoreCase))
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_activeProfile);
            profile = System.Text.Json.JsonSerializer.Deserialize<ConfigProfile>(json)!;
            profile.ProfileName = typedName;
        }
        else
        {
            profile = await _profileRepository.LoadAsync(typedName)
                          ?? new ConfigProfile { ProfileName = typedName };
        }

        _overlayManager.TrySpawnOverlay(target.Hwnd, target.Title, profile);
        var overlay = _overlayManager.GetOverlay(target.Hwnd);
        if (overlay == null) return;

        _overlayManager.SetAllClickThrough(false);
        _configController.SetProfileInfo(typedName, "PokerSite", TableType.SixMax);
        _configController.EnterConfigMode(target.Hwnd, overlay, profile);

        StatusText.Text = "CONFIG MODE ðŸŸ¡ â€” Váº½ bbox â†’ mouseup = OCR test";
    }

    private void Settings_Click(object sender, RoutedEventArgs e)
    {
        ShowSettingsDialog();
    }

    private void ShowSettingsDialog()
    {
        var settingsWindow = new SettingsWindow(_settingsManager, _apiClient, _syncService);
        settingsWindow.Owner = this;
        settingsWindow.ShowDialog();

        // If user activated, re-create ApiClient with new key
        if (settingsWindow.WasActivated || _settingsManager.IsActivated)
        {
            RecreateApiDependentServices();
        }

        RefreshActivationUI();
    }

    /// <summary>
    /// Re-creates ApiClient and all services that depend on it
    /// when the API key or server URL changes.
    /// </summary>
    private void RecreateApiDependentServices()
    {
        _apiClient.Dispose();
        _apiClient = CreateApiClient();

        _syncService.Dispose();
        _syncService = new SyncService(_apiClient, _stateStore, _settingsManager, _noteService);
        _syncService.OnSyncStatusChanged += SyncService_OnStatusChanged;

        // Re-wire action engine with new ApiClient
        _actionEngine = new ActionEngine(_stateStore, _apiClient, _syncService);
        _actionEngine.OnActionApplied += ActionEngine_OnActionApplied;

        // Re-wire input controller
        _inputController = new InputController(_overlayManager, _actionEngine, _stateStore);

        // Re-wire HUD renderer
        _hudRenderer = new HudRenderer(_layoutManager, _stateStore, _inputController, _noteService);
        _hudRenderer.OnOcrBadgeClicked += HudRenderer_OnOcrBadgeClicked;
        _hudRenderer.OnNoteClicked += HudRenderer_OnNoteClicked;

        // Start sync if activated
        if (_settingsManager.IsActivated)
        {
            _syncService.Start();
            StatusText.Text = "âœ” API Key Ä‘Ã£ kÃ­ch hoáº¡t â€” Sáºµn sÃ ng";
        }
    }

    private void Stop_Click(object sender, RoutedEventArgs e)
    {
        _seatEngine.StopAll();
        
        foreach (var (hwnd, _) in _stateStore.Tables.ToList())
        {
            _overlayManager.RemoveOverlay(hwnd);
        }
        
        StatusText.Text = "Tráº¡ng thÃ¡i: ÄÃ£ dá»«ng â¹ â€” Báº¥m QuÃ©t bÃ n Ä‘á»ƒ báº¯t Ä‘áº§u láº¡i";
        TableCountText.Text = "BÃ n Ä‘ang theo dÃµi: 0 / 8";
        TableList.Items.Clear();
    }

    private async void LoadProfile_Click(object sender, RoutedEventArgs e)
    {
        string? profileName = ProfileCombo.SelectedItem?.ToString();
        if (string.IsNullOrEmpty(profileName))
        {
            MessageBox.Show("Chá»n profile trÆ°á»›c.", "RobinHUD",
                MessageBoxButton.OK, MessageBoxImage.Information);
            return;
        }

        var profile = await _profileRepository.LoadAsync(profileName);
        if (profile == null)
        {
            MessageBox.Show($"KhÃ´ng tÃ¬m tháº¥y profile: {profileName}", "RobinHUD");
            return;
        }

        _activeProfile = profile;
        StatusText.Text = $"âœ” ÄÃ£ táº£i profile '{profileName}' ({profile.Seats.Count} seats, {profile.TableType})";
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ HUD Rendering â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private void RefreshAllHuds()
    {
        if (_activeProfile == null) return;

        foreach (var (hwnd, _) in _stateStore.Tables)
        {
            var overlay = _overlayManager.GetOverlay(hwnd);
            if (overlay != null && !_configController.IsConfigMode)
            {
                _hudRenderer.RenderTable(hwnd, overlay, _activeProfile);
            }
        }
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ Helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private void RefreshProfileList()
    {
        ProfileCombo.Items.Clear();
        foreach (var p in _profileRepository.ListProfiles())
            ProfileCombo.Items.Add(p);

        if (ProfileCombo.Items.Count > 0)
            ProfileCombo.SelectedIndex = 0;
    }

    private void MainWindow_Closing(object? sender, System.ComponentModel.CancelEventArgs e)
    {
        _syncTimer?.Stop();
        _hudRefreshTimer?.Stop();
        _seatEngine.Dispose();
        _overlayManager.Dispose();
        _syncService.Dispose();
        _apiClient.Dispose();
    }
}