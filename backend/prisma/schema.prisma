// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PremiumTier {
  FREE
  PRO
  PRO_PLUS
  ENTERPRISE
}

enum InvoiceStatus {
  PENDING
  CONFIRMING
  FINISHED
  FAILED
  EXPIRED
  MANUAL_REVIEW
}

enum UsageActionType {
  AI_ANALYZE
  OCR_NAME
  OCR_HAND
}

// ─── User & Account ─────────────────────────────────────────────────────────

model User {
  id                   String      @id @default(uuid())
  email                String      @unique
  password             String      @default("$2b$10$wzN27C5fWn8.fC/O8v.7.OWY4uNfF/0uO2O8O8O8O8O8O8O8O8O8O") // Default 'admin' hashed for seeding
  premium_tier         PremiumTier @default(FREE)
  is_admin             Boolean     @default(false)
  subscription_expiry  DateTime?
  max_devices          Int         @default(2)
  language             String      @default("en") // "en" | "vi"
  email_verified       Boolean     @default(false)
  email_verify_token   String?     @unique
  email_verify_expires DateTime?
  reset_token          String?     @unique
  reset_token_expires  DateTime?
  created_at           DateTime    @default(now())

  sessions    Session[]
  usages      UserUsage[]
  hands       Hand[]
  invoices    Invoice[]
  players     Player[]      @relation("UserPlayers")
  notes       Note[]        @relation("UserNotes")
  aiConfig    UserAIConfig?
  system_logs SystemLog[]
  api_keys    ApiKey[]
}

model UserAIConfig {
  user_id         String   @id
  system_prompt   String?  @db.Text
  exploit_prompt  String?  @db.Text
  analysis_prompt String?  @db.Text
  model_name      String   @default("gpt-4o")
  temperature     Float    @default(0.7)
  is_enabled      Boolean  @default(true)
  updated_at      DateTime @updatedAt

  // NEW BEHAVIORAL FIELDS (Player Profiling)
  ai_style         String @default("Exploit") // "GTO" | "Balanced" | "Exploit"
  aggression_bias  Int    @default(85) // 0 - 100
  insight_depth    String @default("Deep") // "Quick" | "Deep"
  behavior_toggles Json? // JSON for specific switches

  // NEW BEHAVIORAL FIELDS (Hand Analysis)
  hand_style            String @default("Exploit")
  hand_aggression_bias  Int    @default(85)
  hand_insight_depth    String @default("Deep")
  hand_behavior_toggles Json?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ─── Dynamic Pricing ─────────────────────────────────────────────────────────

model PricingPlan {
  id             String   @id // Connects to PremiumTier enum string (FREE, PRO, etc.)
  name           String
  price          Float
  period         String   @default("/month")
  description    String
  features       String[] // Array of feature descriptions
  ai_limit       Int      @default(0) // AI Analysis per day
  name_ocr_limit Int      @default(0) // Name OCR per day
  hand_ocr_limit Int      @default(0) // Hand OCR per day
  max_devices    Int      @default(1) // Max devices allowed
  ocr_limit      Int      @default(0) // Fallback/Generic OCR limit
  is_popular     Boolean  @default(false)
  color_theme    String   @default("gold") // gold, purple, blue, emerald
  updated_at     DateTime @updatedAt
}

model Session {
  id          String   @id @default(uuid())
  user_id     String
  device_id   String
  ip_address  String?
  last_active DateTime @default(now())
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, device_id])
}

model UserUsage {
  id           String          @id @default(uuid())
  user_id      String
  action_type  UsageActionType
  count        Int             @default(0)
  period_start DateTime        @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, action_type, period_start])
}

// ─── API Keys (Desktop App) ──────────────────────────────────────────────────

model ApiKey {
  id           String    @id @default(uuid())
  user_id      String
  key_hash     String    @unique    // SHA-256 hash of the raw key
  key_prefix   String               // First 8 chars for display (e.g., "pk_a1b2...")
  name         String    @default("Desktop App")
  is_active    Boolean   @default(true)
  last_used_at DateTime?
  created_at   DateTime  @default(now())

  user    User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  devices ApiKeyDevice[]

  @@index([user_id])
}

model ApiKeyDevice {
  id          String   @id @default(uuid())
  api_key_id  String
  device_id   String              // Hardware fingerprint from desktop app
  device_name String?             // e.g., "DESKTOP-ABC123"
  ip_address  String?
  last_used   DateTime @default(now())
  created_at  DateTime @default(now())

  apiKey ApiKey @relation(fields: [api_key_id], references: [id], onDelete: Cascade)

  @@unique([api_key_id, device_id])
  @@index([api_key_id])
}

// ─── Poker Data ──────────────────────────────────────────────────────────────

model Platform {
  id      String   @id @default(uuid())
  name    String   @unique // e.g. "WPT Poker", "GG Poker"
  players Player[]
}

model Player {
  id               String   @id @default(uuid())
  user_id          String
  platform_id      String
  name             String
  playstyle        String?
  aggression_score Int      @default(0)
  looseness_score  Int      @default(0)
  created_at       DateTime @default(now())

  // AI-generated fields (populated when ai_enabled = true)
  ai_playstyle        String?
  ai_aggression_level String?
  ai_aggression_score Int?
  ai_gto_baseline     String?
  ai_exploit_strategy String?
  ai_stats_used       String? // JSON array of stat names used
  ai_analysis_mode    String? // "simple" | "advanced"
  ai_range_matrix     Json? // 13x13 mathematical range logic
  ai_action_breakdown Json? // macro action %s (Raise, Call, Fold)
  ai_last_analyzed_at DateTime?

  // New: Aggregated AI profile from notes (tendencies, leaks, exploitStrategy)
  ai_profile Json?

  user              User              @relation("UserPlayers", fields: [user_id], references: [id], onDelete: Cascade)
  platform          Platform          @relation(fields: [platform_id], references: [id])
  notes             Note[]
  stats             PlayerStats?
  analysis_contexts AnalysisContext[]
  patterns          PlayerPattern[]

  @@unique([user_id, platform_id, name])
  @@index([user_id])
  @@index([name])
  @@index([created_at])
  @@index([user_id, playstyle]) // Optimized for dashboard grouping
}

model PlayerPattern {
  id          String   @id @default(uuid())
  player_id   String
  pattern     String
  confidence  Float    @default(0.1) // Range: 0.0 to 1.0
  occurrences Int      @default(1)
  decay_score Float    @default(1.0)
  last_seen   DateTime @default(now())
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, pattern])
  @@index([player_id])
}

model Note {
  id              String   @id @default(uuid())
  user_id         String
  player_id       String
  street          String
  note_type       String   @default("TEXT")
  content         String
  metadata        Json?    // Structured context: pot_type, board_bucket, facing, action, severity, etc.
  category        String   @default("GENERAL") // "EXPLOIT" | "LEAK" | "TELL" | "GENERAL"
  source          String   @default("custom")  // "template" | "custom" | "ai"
  is_ai_generated Boolean  @default(false)
  hand_id         String?  // Optional link to analyzed hand
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt          // Track last edit time

  user   User   @relation("UserNotes", fields: [user_id], references: [id], onDelete: Cascade)
  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)
  hand   Hand?  @relation(fields: [hand_id], references: [id])

  @@index([user_id])
  @@index([player_id])
  @@index([user_id, created_at]) // Fast: "get my recent notes"
}

model Hand {
  id          String   @id @default(uuid())
  user_id     String
  hand_hash   String   @unique // Canonical hash for caching
  raw_input   String   @default("") // Original text or image URL
  input_type  String   @default("text") // "text" | "image"
  parsed_data Json? // Structured hand JSON (positions, actions, board)
  ai_analysis Json? // AI output: heroMistakes, villainMistakes, betterLine, exploit
  tags        String[] @default([])
  created_at  DateTime @default(now())

  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notes       Note[]
  system_logs SystemLog[]

  @@index([user_id])
}

model Template {
  id       String @id @default(uuid())
  label    String
  category String
  weight   Int    @default(0)

  @@unique([label, category])
}

model PlayerStats {
  id              String @id @default(uuid())
  player_id       String @unique
  vpip            Float?
  rfi             Float?
  pfr             Float?
  three_bet       Float?
  fold_to_3bet    Float?
  cbet            Float?
  fold_to_cbet    Float?
  wtsd            Float?
  wsd             Float?
  aggression_freq Float?
  steal           Float?
  fold_to_steal   Float?
  check_raise     Float?
  total_hands     Int?

  player Player @relation(fields: [player_id], references: [id])
}

model AppSettings {
  id            String  @id @default("singleton")
  ai_enabled    Boolean @default(false)
  analysis_mode String  @default("simple") // "simple" | "advanced"
}

model AnalysisContext {
  id            String   @id @default(uuid())
  player_id     String
  position      String // "IP" | "OOP"
  hero_stack    Float // hero stack in BB
  villain_stack Float // villain stack in BB
  created_at    DateTime @default(now())

  player Player @relation(fields: [player_id], references: [id])
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid())
  user_id         String
  nowpayments_id  String?       @unique // External invoice ID from provider
  payment_id      String?       @unique // External blockchain payment ID
  amount          Float // The base price in USD
  actually_paid   Float? // Total USD equivalent received
  currency        String        @default("USD")
  status          InvoiceStatus @default(PENDING)
  tier_requested  PremiumTier
  is_upgraded     Boolean       @default(false)
  last_webhook_at DateTime?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  user   User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  events PaymentEvent[]
}

model PaymentEvent {
  id              String   @id @default(uuid())
  invoice_id      String
  event_type      String // Webhook, State Transition, Error
  payload         Json // Masked JSON payload
  signature_valid Boolean?
  processed       Boolean  @default(false)
  created_at      DateTime @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
}

model SystemLog {
  id         String   @id @default(uuid())
  user_id    String
  hand_id    String?
  event_type String // "OCR_FEEDBACK" | "AI_LEARNING" | "PROFILE_EVOLUTION" | "SYSTEM"
  message    String
  metadata   Json? // Contextual data like old_val, new_val
  created_at DateTime @default(now())

  user User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  hand Hand? @relation(fields: [hand_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([hand_id])
  @@index([created_at])
}

// ─── GTO Strategy Data ──────────────────────────────────────────────────────

model GtoSpot {
  id           String  @id @default(uuid())
  position     String  // "BTN_vs_BB" | "SB_vs_BB" | "CO_vs_BTN"
  board_bucket String  // "A_dry" | "K_dry" | ...
  street       String  // "flop" | "turn" | "river"
  action_line  String? // null (flop) | "cbet33_call" | "cbet75_call" | "xx"
  turn_type    String? // null (flop) | "blank" | "overcard" | "board_pair" | ...
  river_type   String? // null (flop/turn) | "board_pair" | "flush_card" | "overcard" | "blank"
  board        String  // Full board cards e.g. "As,7d,2c" or "As,7d,2c,5c,7c"

  pot       Float
  eff_stack Float

  // Overall aggregated strategy (root node: check/bet actions)
  oop_check     Float @default(0)
  oop_bet_small Float @default(0)
  oop_bet_big   Float @default(0)
  ip_check      Float @default(0)
  ip_bet_small  Float @default(0)
  ip_bet_big    Float @default(0)

  // Facing-bet strategy (fold/call/raise when action_line = 'facing_cbet33' etc.)
  oop_fold  Float @default(0)
  oop_call  Float @default(0)
  oop_raise Float @default(0)

  hands GtoHand[]

  @@unique([position, board_bucket, street, action_line, turn_type, river_type])
  @@index([position, board_bucket, street])
  @@index([board_bucket])
}

model GtoHand {
  id         String @id @default(uuid())
  spot_id    String
  player     String // "oop" | "ip"
  hand       String // "AcKd"
  hand_class String // "top_pair" | "flush_draw" | "air" | ...

  check     Float @default(0)
  bet_small Float @default(0)
  bet_big   Float @default(0)

  // Facing-bet actions (used when spot.action_line = 'facing_cbet33' etc.)
  fold  Float @default(0)
  call  Float @default(0)
  raise Float @default(0)

  spot GtoSpot @relation(fields: [spot_id], references: [id], onDelete: Cascade)

  @@index([spot_id, player])
  @@index([hand_class])
  @@index([spot_id, player, hand_class])
}

model GtoQueryLog {
  id               String   @id @default(uuid())
  user_id          String?
  // User Input
  board            String
  position         String
  hole_cards       String
  action_history   String?
  // AI Response
  ai_response      Json?    // Stores the FULL raw JSON string generated by the LLM
  // Feedback
  is_helpful       Boolean? // true/false/null
  feedback_reason  String?
  
  created_at       DateTime @default(now())
}
